# Supabase — fill these in once the project exists, then copy to .env.local
# The site renders with sensible built-in defaults even when these are blank,
# so you can preview the design immediately before wiring the database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the browser. Used by admin/seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical/OG tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://www.foscod.org
